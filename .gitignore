#-------------------------
# Operating System Junk
#-------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk
*~
.directory
.Trash-*

#-------------------------
# Environment & Secrets
#-------------------------
.env
.vagrant
Vagrantfile

#-------------------------
# CodeIgniter Writable Data
#-------------------------
/writable/cache/*
!/writable/cache/index.html

/writable/logs/*
!/writable/logs/index.html

/writable/session/*
!/writable/session/index.html

/writable/uploads/*
!/writable/uploads/index.html

/writable/debugbar/*
!/writable/debugbar/index.html

php_errors.log

#-------------------------
# User-generated Public Uploads
#-------------------------
/public/uploads/activities/*
!/public/uploads/activities/.gitkeep

/public/uploads/officials/*
!/public/uploads/officials/.gitkeep

/public/uploads/programs/*
!/public/uploads/programs/.gitkeep

/public/uploads/content_studio/*
!/public/uploads/content_studio/.gitkeep

/public/uploads/settings/*
!/public/uploads/settings/.gitignore

#-------------------------
# Composer / Testing
#-------------------------
/vendor/
/phpunit
/tests/coverage*
/results/
/phpunit.xml

